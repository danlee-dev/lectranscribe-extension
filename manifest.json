{
  "manifest_version": 3,
  "name": "LecTranscribe",
  "version": "1.3.0",
  "description": "LMS 강의 + YouTube 영상 자동 감지 및 전사",
  "permissions": [
    "webRequest",
    "storage",
    "activeTab",
    "tabCapture",
    "offscreen",
    "scripting"
  ],
  "host_permissions": [
    "https://mylms.korea.ac.kr/*",
    "https://kulms.korea.ac.kr/*",
    "https://kucom.korea.ac.kr/*",
    "https://korea-cms-object.cdn.gov-ntruss.com/*",
    "https://www.youtube.com/*",
    "https://youtube.com/*",
    "https://*.googlevideo.com/*",
    "https://lectranscribe.vercel.app/*",
    "https://lectranscribe-backend-production.up.railway.app/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://mylms.korea.ac.kr/*",
        "https://kulms.korea.ac.kr/*",
        "https://kucom.korea.ac.kr/*"
      ],
      "js": ["i18n.js", "content.js"],
      "css": ["content.css"]
    },
    {
      "matches": [
        "https://www.youtube.com/watch*",
        "https://www.youtube.com/shorts/*"
      ],
      "js": ["youtube-intercept.js"],
      "world": "MAIN",
      "run_at": "document_start"
    },
    {
      "matches": [
        "https://www.youtube.com/*",
        "https://youtube.com/*"
      ],
      "js": ["i18n.js", "youtube-content.js"],
      "css": ["content.css"]
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
